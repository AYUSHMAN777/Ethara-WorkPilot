# --- Local dev ---
# Leave empty: Vite proxies /api to the backend (see vite.config.js).
VITE_API_URL=

# Optional: where Vite proxies /api in dev (default http://127.0.0.1:5000)
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# --- Vercel (production) ---
# REQUIRED on Vercel: set in Project → Settings → Environment Variables for "Production"
# (and Preview if you use preview deploys). Value = your Railway public URL only, e.g.:
#   https://ethara-api.up.railway.app
# No trailing slash. No /api — the client appends /api itself.
# VITE_API_URL=https://your-railway-service.up.railway.app
