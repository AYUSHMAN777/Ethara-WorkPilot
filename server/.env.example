NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ethara-workpilot?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
# Local: Vite default. Production (Railway): REQUIRED — your Vercel site(s), comma-separated, no trailing slashes.
# Example: https://ethara-workpilot.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://127.0.0.1:5173
# Set to true only for bootstrapping the first admin account in development
ALLOW_ADMIN_SIGNUP=false

# Railway: set variables in the dashboard — .env files are NOT loaded (platform env only).
